{
  "executionPlatform": "Camunda Cloud",
  "executionPlatformVersion": "8.8.0",
  "exporter": {
    "name": "Camunda Modeler",
    "version": "8.8.0"
  },
  "schemaVersion": 19,
  "id": "finance-application",
  "components": [
    {
      "type": "textfield",
      "label": "Customer name",
      "key": "customerName",
      "validate": {
        "required": true
      }
    },
    {
      "type": "number",
      "label": "Order total",
      "key": "orderTotal",
      "validate": {
        "required": true,
        "min": 100
      }
    },
    {
      "type": "select",
      "label": "Finance decision for demo",
      "key": "financeDecision",
      "values": [
        {
          "label": "Approved",
          "value": "approved"
        },
        {
          "label": "Declined",
          "value": "declined"
        }
      ],
      "defaultValue": "approved",
      "validate": {
        "required": true
      }
    }
  ],
  "type": "default"
}
