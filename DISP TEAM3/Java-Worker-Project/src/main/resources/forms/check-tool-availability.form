{
  "executionPlatform": "Camunda Cloud",
  "executionPlatformVersion": "8.8.0",
  "exporter": {
    "name": "Camunda Modeler",
    "version": "8.8.0"
  },
  "schemaVersion": 19,
  "id": "check-tool-availability",
  "components": [
    {
      "type": "textfield",
      "label": "Tool ID",
      "key": "toolId",
      "validate": {
        "required": true
      }
    },
    {
      "type": "textfield",
      "label": "Customer name",
      "key": "customerName",
      "validate": {
        "required": true
      }
    },
    {
      "type": "checkbox",
      "label": "Tool available",
      "key": "toolAvailable",
      "defaultValue": true
    }
  ],
  "type": "default"
}
