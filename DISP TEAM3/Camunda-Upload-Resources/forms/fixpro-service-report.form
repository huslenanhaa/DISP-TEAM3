{
  "executionPlatform": "Camunda Cloud",
  "executionPlatformVersion": "8.8.0",
  "exporter": {
    "name": "Camunda Modeler",
    "version": "8.8.0"
  },
  "schemaVersion": 19,
  "id": "fixpro-service-report",
  "components": [
    {
      "type": "textfield",
      "label": "Technician ID",
      "key": "technicianId",
      "validate": {
        "required": true
      }
    },
    {
      "type": "textarea",
      "label": "Service notes",
      "key": "serviceNotes",
      "validate": {
        "required": true
      }
    },
    {
      "type": "number",
      "label": "Invoice amount",
      "key": "invoiceAmount",
      "validate": {
        "required": true,
        "min": 0
      }
    }
  ],
  "type": "default"
}
