        <zeebe:assignmentDefinition assignee="demo" />
      </bpmn:extensionElements>
      <bpmn:incoming>SF_0002</bpmn:incoming>
      <bpmn:outgoing>SF_0003</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:receiveTask id="cT_rcvBookConf" name="Receive booking confirmation" messageRef="Msg_receive-booking-confirmation">
      <bpmn:incoming>SF_0003</bpmn:incoming>
      <bpmn:outgoing>SF_0004</bpmn:outgoing>
    </bpmn:receiveTask>
    <bpmn:manualTask id="cT_useTool" name="Use hired tool">
      <bpmn:incoming>SF_0008</bpmn:incoming>
      <bpmn:outgoing>Flow_0bua32t</bpmn:outgoing>
    </bpmn:manualTask>
    <bpmn:exclusiveGateway id="cG_confirmed" name="Booking confirmed?" gatewayDirection="Diverging" default="SF_0005">
      <bpmn:incoming>SF_0004</bpmn:incoming>
      <bpmn:outgoing>SF_0005</bpmn:outgoing>
      <bpmn:outgoing>SF_0006</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:manualTask id="cT_collectTool" name="Collect tool from ProBuild">
      <bpmn:incoming>SF_0005</bpmn:incoming>
      <bpmn:outgoing>SF_0008</bpmn:outgoing>
    </bpmn:manualTask>
    <bpmn:manualTask id="cT_takeGoods" name="Take goods immediately (finance approved)">
      <bpmn:incoming>SF_0022</bpmn:incoming>
      <bpmn:outgoing>SF_0024</bpmn:outgoing>
    </bpmn:manualTask>
    <bpmn:endEvent id="cE_unavailEnd" name="Tool unavailable">
      <bpmn:incoming>SF_0007</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:receiveTask id="cT_rcvUnavail" name="Receive unavailability notice" messageRef="Msg_receive-unavailability-notice">
      <bpmn:incoming>SF_0006</bpmn:incoming>
      <bpmn:outgoing>SF_0007</bpmn:outgoing>
    </bpmn:receiveTask>
    <bpmn:userTask id="cT_optInFin" name="Opt in to interest-free finance">
      <bpmn:extensionElements>
        <zeebe:userTask />
        <zeebe:formDefinition formId="finance-application" bindingType="latest" />
        <zeebe:assignmentDefinition assignee="demo" />
      </bpmn:extensionElements>
      <bpmn:incoming>SF_0014</bpmn:incoming>
      <bpmn:outgoing>SF_0020</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="cG_tradeCard" name="Trade Card member and purchase ≥ £100?" gatewayDirection="Diverging" default="SF_0015">
      <bpmn:incoming>SF_0013</bpmn:incoming>
      <bpmn:outgoing>SF_0014</bpmn:outgoing>
      <bpmn:outgoing>SF_0015</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:receiveTask id="cT_rcvFinDecision" name="Receive finance decision" messageRef="Msg_receive-finance-decision">
      <bpmn:incoming>SF_0020</bpmn:incoming>
      <bpmn:outgoing>SF_0021</bpmn:outgoing>
    </bpmn:receiveTask>
    <bpmn:exclusiveGateway id="cG_finApproved" name="Finance approved?" gatewayDirection="Diverging" default="SF_0022">
      <bpmn:incoming>SF_0021</bpmn:incoming>
      <bpmn:outgoing>SF_0023</bpmn:outgoing>
      <bpmn:outgoing>SF_0022</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:userTask id="cT_monthlyRepay" name="Make monthly repayments to FinTrust (6 or 12 months)">
      <bpmn:extensionElements>
        <zeebe:userTask />
        <zeebe:formDefinition formId="payment" bindingType="latest" />
        <zeebe:assignmentDefinition assignee="demo" />
      </bpmn:extensionElements>
      <bpmn:incoming>SF_0024</bpmn:incoming>
      <bpmn:outgoing>SF_0025</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:endEvent id="cE_finPaid" name="Finance repaid">
      <bpmn:incoming>SF_0025</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:startEvent id="cS_retail" name="Wants to buy materials or tools">
      <bpmn:outgoing>SF_0011</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:startEvent id="cS_hire" name="Wants to hire a tool">
      <bpmn:outgoing>SF_0001</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:userTask id="cT_payStd" name="Pay by cash or card">
      <bpmn:extensionElements>
        <zeebe:userTask />
        <zeebe:formDefinition formId="payment" bindingType="latest" />
        <zeebe:assignmentDefinition assignee="demo" />
      </bpmn:extensionElements>
      <bpmn:incoming>SF_0015</bpmn:incoming>
      <bpmn:outgoing>Flow_0jidb8x</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:receiveTask id="cT_rcvOrderConf" name="Receive order confirmation" messageRef="Msg_receive-order-confirmation">
      <bpmn:incoming>Flow_0jidb8x</bpmn:incoming>
      <bpmn:outgoing>SF_0019</bpmn:outgoing>
    </bpmn:receiveTask>
    <bpmn:endEvent id="cE_retailEnd" name="Purchase complete">
      <bpmn:incoming>SF_0019</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:receiveTask id="cT_rcvPayFail" name="Receive payment failure notice" messageRef="Msg_receive-payment-failure-notice">
      <bpmn:outgoing>SF_0026</bpmn:outgoing>
    </bpmn:receiveTask>
    <bpmn:endEvent id="cE_payFailEnd" name="Booking failed — end">
      <bpmn:incoming>SF_0026</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="SF_0011" sourceRef="cS_retail" targetRef="cT_browse" />
    <bpmn:sequenceFlow id="SF_0012" sourceRef="cT_browse" targetRef="cT_placeOrder" />
    <bpmn:sequenceFlow id="SF_0013" sourceRef="cT_placeOrder" targetRef="cG_tradeCard" />
    <bpmn:sequenceFlow id="SF_0023" name="declined" sourceRef="cG_finApproved" targetRef="cE_finDeclined">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=declined</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="SF_0001" sourceRef="cS_hire" targetRef="cT_checkAvail" />
    <bpmn:sequenceFlow id="SF_0002" sourceRef="cT_checkAvail" targetRef="cT_submitHire" />
    <bpmn:sequenceFlow id="SF_0003" sourceRef="cT_submitHire" targetRef="cT_rcvBookConf" />
    <bpmn:sequenceFlow id="SF_0004" sourceRef="cT_rcvBookConf" targetRef="cG_confirmed" />
    <bpmn:sequenceFlow id="SF_0010" sourceRef="cT_returnTool" targetRef="cE_hireEnd" />
    <bpmn:sequenceFlow id="SF_0008" sourceRef="cT_collectTool" targetRef="cT_useTool" />
    <bpmn:sequenceFlow id="SF_0005" name="yes" sourceRef="cG_confirmed" targetRef="cT_collectTool"></bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="SF_0006" name="no" sourceRef="cG_confirmed" targetRef="cT_rcvUnavail">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=unavailable</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="SF_0022" name="approved" sourceRef="cG_finApproved" targetRef="cT_takeGoods"></bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="SF_0024" sourceRef="cT_takeGoods" targetRef="cT_monthlyRepay" />
    <bpmn:sequenceFlow id="SF_0007" sourceRef="cT_rcvUnavail" targetRef="cE_unavailEnd" />
    <bpmn:sequenceFlow id="SF_0014" name="yes — Trade Card" sourceRef="cG_tradeCard" targetRef="cT_optInFin">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=tradeCard</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="SF_0020" sourceRef="cT_optInFin" targetRef="cT_rcvFinDecision" />
    <bpmn:sequenceFlow id="SF_0015" name="no" sourceRef="cG_tradeCard" targetRef="cT_payStd"></bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="SF_0021" sourceRef="cT_rcvFinDecision" targetRef="cG_finApproved" />
    <bpmn:sequenceFlow id="SF_0025" sourceRef="cT_monthlyRepay" targetRef="cE_finPaid" />
    <bpmn:sequenceFlow id="Flow_0jidb8x" sourceRef="cT_payStd" targetRef="cT_rcvOrderConf" />
    <bpmn:sequenceFlow id="SF_0019" sourceRef="cT_rcvOrderConf" targetRef="cE_retailEnd" />
    <bpmn:sequenceFlow id="SF_0026" sourceRef="cT_rcvPayFail" targetRef="cE_payFailEnd" />
    <bpmn:endEvent id="cE_hireEnd" name="Hire journey complete">
      <bpmn:incoming>SF_0010</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:manualTask id="cT_returnTool" name="Return tool on agreed date">
      <bpmn:incoming>Flow_08n4r2t</bpmn:incoming>
      <bpmn:outgoing>SF_0010</bpmn:outgoing>
    </bpmn:manualTask>
    <bpmn:endEvent id="cE_lateFee" name="Late-fee reminder sent">
      <bpmn:incoming>Flow_0a9vnzw</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_0bua32t" name="has returned date passed" sourceRef="cT_useTool" targetRef="Gateway_0z05dmx" />
    <bpmn:exclusiveGateway id="Gateway_0z05dmx" default="Flow_08n4r2t">
      <bpmn:incoming>Flow_0bua32t</bpmn:incoming>
      <bpmn:outgoing>Flow_08n4r2t</bpmn:outgoing>
      <bpmn:outgoing>Flow_0a9vnzw</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:sequenceFlow id="Flow_08n4r2t" name="no" sourceRef="Gateway_0z05dmx" targetRef="cT_returnTool" />
    <bpmn:sequenceFlow id="Flow_0a9vnzw" name="yes" sourceRef="Gateway_0z05dmx" targetRef="cE_lateFee">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=yes</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
  </bpmn:process>
  <bpmn:process id="Proc_ProBuild" name="ProBuild Supplies Ltd" isExecutable="true">
    <bpmn:laneSet id="LS_ProBuild">
