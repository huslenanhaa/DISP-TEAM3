        <bpmn:flowNodeRef>whT_relocate</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>whE_toolReady</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>imsT_statusInService</bpmn:flowNodeRef>
