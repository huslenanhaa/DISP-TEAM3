      </bpmn:extensionElements>
      <bpmn:incoming>SF_0001</bpmn:incoming>
      <bpmn:outgoing>SF_0002</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="cT_submitHire" name="Submit hire request">
