        <zeebe:assignmentDefinition assignee="demo" />
      </bpmn:extensionElements>
      <bpmn:incoming>SF_0011</bpmn:incoming>
      <bpmn:outgoing>SF_0012</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="cT_placeOrder" name="Select products and place order">
      <bpmn:extensionElements>
        <zeebe:userTask />
        <zeebe:formDefinition formId="place-retail-order" bindingType="latest" />
        <zeebe:assignmentDefinition assignee="demo" />
      </bpmn:extensionElements>
      <bpmn:incoming>SF_0012</bpmn:incoming>
      <bpmn:outgoing>SF_0013</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:endEvent id="cE_finDeclined" name="Finance declined">
      <bpmn:incoming>SF_0023</bpmn:incoming>
    </bpmn:endEvent>
